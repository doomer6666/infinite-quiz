## Создать квиз с изображением и описанием
POST http://localhost:4010/quizzes
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJlbWFpbCI6InRvcmFuc0BvdmVybG9vay5uZXQiLCJuYW1lIjoiSmVmcmV5IEVwc3RpbmUiLCJpZCI6IjZhNTI4YjI0ZWE4OTMyNjFmZDY5NTY4ZCIsImlhdCI6MTc4Mzg3NzkwNiwiZXhwIjoxNzg0MDUwNzA2fQ.VxeZ-3TitBmwA9-m1wi7zc5Y6kRNylkqO20FXZRM8-A

{
  "title": "История Древнего Рима",
  "category": "history",
  "status": "published",
  "imageFilename": "rome.jpg",
  "questions": [
    {
      "text": "В каком году был основан Рим?",
      "timeLimit": 20,
      "points": 15,
      "answers": [
        { "text": "753 до н.э.", "isCorrect": true },
        { "text": "509 до н.э.", "isCorrect": false },
        { "text": "27 до н.э.", "isCorrect": false }
      ]
    },
    {
      "text": "Кто был первым императором Рима?",
      "timeLimit": 15,
      "points": 10,
      "answers": [
        { "text": "Юлий Цезарь", "isCorrect": false },
        { "text": "Август", "isCorrect": true },
        { "text": "Нерон", "isCorrect": false }
      ]
    }
  ]
}

