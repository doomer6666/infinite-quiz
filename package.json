    "npm-run-all": "^4.1.5",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "http-status-codes": "^2.3.0",
    "pino": "^10.3.1"
  }
}
